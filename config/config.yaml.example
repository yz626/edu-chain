# edu-chain 配置文件示例
# 复制此文件为 config.yaml 并修改相应配置

# 服务器配置
server:
  host: 0.0.0.0
  port: 8080
  mode: debug
  read_timeout: 30    # 读取超时(秒)
  write_timeout: 30   # 写入超时(秒)

# gRPC 配置
grpc:
  host: 0.0.0.0
  port: 9090

# 数据库配置
database:
  name: mysql           # 数据库类型
  host: localhost       # 数据库地址
  port: 3306            # 数据库端口
  username: root        # 数据库用户名
  password: "123456"   # 数据库密码
  database: edu_chain   # 数据库名称
  sslmode: disable      # SSL模式
  max_open_conns: 10    # 最大连接数
  max_idle_conns: 10    # 最大空闲连接数
  max_lifetime: 30      # 连接最大生命周期 单位秒
  timeout: 30           # 连接超时时间 单位秒

# Redis配置
redis:
  host: localhost   # Redis服务地址
  port: 6379        # Redis服务端口
  password: ""      # Redis密码
  db: 0             # Redis数据库索引
  pool_size: 10    # 连接池大小

# 日志配置
logger:
  level: info            # 日志级别 (debug, info, warn, error, fatal)
  format: json           # 日志格式 (json, console)
  directory: logs        # 日志目录
  console: true          # 是否输出到控制台
  max_size: 100         # 单个日志文件最大大小(MB)
  max_age: 30           # 日志文件保留天数
  max_backups: 10       # 保留的日志文件数量
  enable_stacktrace: false  # 是否启用堆栈跟踪

# jwt 配置
jwt:
  secret: "edu-chain-secret-key-change-in-production"  # jwt密钥
  expire: 3600       # 访问令牌过期时间 单位秒(1小时)
  refresh_expire: 604800  # 刷新令牌过期时间 单位秒(7天)
  issuer: "edu-chain"     # JWT签发者

# =====================================================
# 区块链配置 (FISCO BCOS 2.0)
# =====================================================
blockchain:
  enabled: true                    # 是否启用区块链
  type: "fiscobcos"               # 区块链类型: fiscobcos, ethereum, fabric
  
  fiscobcos:
    # 节点连接配置
    node_url: "http://127.0.0.1:8545"   # RPC节点URL (必填)
    group_id: "1"                        # 群组ID (必填)
    chain_id: 1                          # 链ID
    
    # 账户配置 (私钥和私钥文件二选一，优先使用私钥)
    # 方式1: 直接使用私钥字符串 (十六进制, 不带0x前缀)
    account_key: ""                       
    # 方式2: 从私钥文件加载 (私钥为空时使用)
    account_key_file: "./keys/node.key"   
    
    # 合约配置
    contract_address: "0x0000000000000000000000000000000000000000"  # 部署后的合约地址 (必填)
    
    # 合约ABI配置 (ABI字符串和ABI文件二选一，优先使用ABI字符串)
    # 方式1: 直接使用ABI JSON字符串
    contract_abi: ""                      
    # 方式2: 从ABI文件加载 (ABI字符串为空时使用)
    contract_abi_path: "./bin/contracts/CertificateRegistry.abi"
    
    # 连接配置
    timeout: 30s                          # 请求超时 (默认30秒)
    max_retries: 3                        # 最大重试次数 (默认3次)
    confirm_timeout: 60s                   # 交易确认超时 (默认60秒)
    gas_limit: 3000000                    # Gas限制 (默认3000000)
    
    # 国密配置 (可选, 仅在使用国密版本时配置)
    # gm_enable: false                    # 是否启用国密
    # gm_account_key: ""                  # 国密私钥 (十六进制)
    # gm_account_key_file: ""             # 国密私钥文件
    # gm_account_cert: "./certs/gm-node.crt"    # 国密证书
    # gm_ssl_ca: "./certs/gmca.crt"       # 国密CA证书
    # gm_ssl_cert: "./certs/gmnode.crt"    # 国密节点证书
    # gm_ssl_key: "./certs/gmnode.key"    # 国密节点私钥

# =====================================================
# FISCO BCOS 部署指南
# =====================================================
#
# 1. 启动FISCO BCOS节点
#    使用Docker快速启动:
#    docker run -d --name fisco-bcos \
#      -v ~/fisco/nodes:/data \
#      -p 8545:8545 \
#      -p 30300:30300 \
#      fiscoorg/fisco-bcos:latest
#
# 2. 部署智能合约
#    使用FISCO BCOS控制台部署 CertificateRegistry.sol
#    部署后获取合约地址，填入上面的 contract_address
#
# 3. 配置账户
#    方式1: 直接使用私钥 (从节点配置文件获取)
#    account_key: "a1b2c3d4e5f6..."
#    
#    方式2: 从私钥文件加载
#    account_key_file: "nodes/127.0.0.1/node0/conf/node.key"
#
# 4. 配置ABI
#    方式1: 直接粘贴ABI JSON字符串
#    contract_abi: '[{"constant":true,...}]'
#    
#    方式2: 从ABI文件加载
#    contract_abi_path: "bin/contracts/CertificateRegistry.abi"
#
# 5. 测试连接
#    使用 curl 测试节点连接:
#    curl -X POST http://127.0.0.1:8545 \
#      -H "Content-Type: application/json" \
#      -d '{"jsonrpc":"2.0","method":"getBlockNumber","params":[{"groupId":"1"}],"id":1}'
